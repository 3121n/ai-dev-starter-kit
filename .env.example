# Copy this file to .env and fill in your own values.
# .env is gitignored — it will NEVER be committed. Keep it that way.
# These same keys also go into Netlify (Site settings → Environment variables),
# because the build runs in Netlify's cloud and does NOT see your local .env.

# --- Anthropic / Claude Code ---
# From console.anthropic.com (a SEPARATE account from claude.ai).
# Shown only once when you create it. Starts with sk-ant-
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# --- Notion integration ---
# From notion.so/my-integrations. Starts with ntn_
# Remember: creating the token is NOT enough — you must also SHARE each
# page/database with the integration, or you'll get "Could not find object".
NOTION_API_KEY=ntn_xxxxxxxxxxxxxxxxxxxx

# --- Memory (Pinecone) — optional, for long-term recall ---
# From app.pinecone.io. Note your index's DIMENSION must match your
# embedding model (e.g. 1536). Mismatch = silent failures.
PINECONE_API_KEY=pcsk_xxxxxxxxxxxxxxxxxxxx
PINECONE_INDEX=ai-dev-starter

# --- GitHub (only if a script needs it; normally `gh` handles auth) ---
# Personal access token from github.com/settings/tokens
# GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx
